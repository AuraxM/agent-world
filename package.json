{
  "name": "agent-world",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "DATABASE_URL=$(pwd)/data/agent-world.db AGENT_WORLD_CONFIGS_DIR=$(pwd)/configs pnpm --filter @agw/server dev & next dev",
    "dev:server": "DATABASE_URL=$(pwd)/data/agent-world.db AGENT_WORLD_CONFIGS_DIR=$(pwd)/configs pnpm --filter @agw/server dev",
    "dev:web": "next dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx packages/db/src/migrate.ts",
    "db:reset": "tsx scripts/db-reset.ts && tsx packages/db/src/migrate.ts",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@agw/config": "workspace:*",
    "@agw/db": "workspace:*",
    "@agw/domain": "workspace:*",
    "@agw/llm": "workspace:*",
    "@agw/shared": "workspace:*",
    "@agw/systems": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.4",
    "openai": "^6.35.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-force-graph-2d": "^1.29.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild", "sharp", "unrs-resolver"]
  }
}
